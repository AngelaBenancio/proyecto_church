// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model IntencionMisa {
  id                String   @id @default(uuid())
  nombreSolicitante String
  emailSolicitante  String
  telefonoSolicitante String
  tipoIntencion     String   // DIFUNTO, SALUD, ACCION_DE_GRACIAS, CUMPLEANOS, OTRO
  nombreIntencion   String   // Nombre del difunto o la intención
  fechaMisa         DateTime
  horaMisa          String   // e.g. "07:00 AM", "06:00 PM", "07:00 PM"
  montoOfrenda      Decimal  @default(0.00)
  codigoYape        String   // Exactamente 3 dígitos
  estado            String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Bautizo {
  id                         String   @id @default(uuid())
  nombreBautizado            String
  fechaNacimiento            DateTime
  fechaBautizo               DateTime?
  nombrePadre                String
  nombreMadre                String
  nombrePadrino              String
  nombreMadrina              String
  dniBautizado               String
  dniPadres                  String
  dniPadrinos                String
  documentoActaNacimientoUrl String?
  documentoDniPadresUrl      String?
  documentoDniPadrinosUrl    String?
  estado                     String   @default("PENDIENTE") // PENDIENTE, APROBADO, RECHAZADO
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Feligres {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  telefono  String
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HorarioRestringido {
  id        String   @id @default(uuid())
  fechaStr  String   // Formato YYYY-MM-DD
  hora      String?  // Si es null, se restringe todo el día
  motivo    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fechaStr, hora])
}

model ServicioLiturgico {
  id                     String   @id // e.g. "DIFUNTO", "HONRAS", "SALUD", "CUMPLEANOS", "ACCION_GRACIAS", "BAUTIZO", "MATRIMONIO", "COMUNION", "CONFIRMACION"
  nombre                 String   // e.g. "Misa de Honras" o "Primera Comunión"
  categoria              String   // "INTENCION" o "SACRAMENTO"
  montoSugerido          Decimal  @db.Decimal(10, 2) @default(10.00)
  descripcion            String?  @db.Text
  activo                 Boolean  @default(true)
  
  // Banderas de configuración dinámica de formularios
  requiereFestejado      Boolean  @default(false) // Nombre del festejado/difunto
  labelFestejado         String?  // Ej. "Nombre del difunto" o "Nombre del comulgante"
  requiereFallecido      Boolean  @default(false) // Agrega leyenda "Q.E.P.D."
  requiereConyuge        Boolean  @default(false) // Campo novio/a (Matrimonio)
  requierePadresPadrinos Boolean  @default(false) // Campos de padres y padrinos (Bautizo)
  
  // Lista de códigos de documentos requeridos separados por coma (e.g. "DNI_NINO,ACTA_NACIMIENTO")
  documentosRequeridos   String?  
  
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model HorarioDisponible {
  id               String    @id @default(uuid())
  hora             String    // Formato "HH:MM" (ej. "07:00", "18:00")
  diaSemana        Int?      // 0 = Domingo, 1 = Lunes... o null si es fecha especial
  fechaEspecifica  DateTime? // Si es habilitado solo para un día concreto (misa de honras especial)
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([hora, diaSemana, fechaEspecifica])
}


model SystemSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
